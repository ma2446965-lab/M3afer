rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Fields a normal user is allowed to change on their own profile.
    // Payment/role fields are pinned by NAME (works even when a field is
    // absent on older docs) — role & legacy subscription tiers can only change
    // via the admin rule below, and subscribed/subscription*Date only via the
    // Fatorak webhook (Admin SDK) or the cron job.
    function onlySelfManagedFieldsChanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
        ["role", "subscription", "subscriptionActive", "subscribed", "subscriptionStartDate", "subscriptionEndDate", "lastPayment"]
      );
    }

    match /users/{userId} {
      // Owner can read their own profile; admin can read any profile.
      allow read: if isOwner(userId) || isAdmin();

      // Owner can create their own profile document once, on signup.
      // Payment fields MUST start unset/false — clients can never self-grant
      // a subscription; only the webhook (Admin SDK) sets subscribed: true.
      allow create: if isOwner(userId) &&
        request.resource.data.role == "user" &&
        request.resource.data.subscription == "free" &&
        request.resource.data.subscriptionActive == false &&
        request.resource.data.subscribed == false;

      // Owner can update their own profile ONLY if role/subscription fields are untouched.
      allow update: if isOwner(userId) && onlySelfManagedFieldsChanged();

      // Admin can update any profile, including role/subscription (for manual upgrades).
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /users/{userId}/pdfs/{pdfId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // ===================== Admin-managed content =====================
    // Any signed-in user can READ subjects & slots (students browse them on
    // /booking). Writes are admin-only, EXCEPT the student booking
    // transaction on slots.bookedCount — see studentBookingTx() below.

    function validSubject() {
      let d = request.resource.data;
      return d.keys().hasAll(["name", "description", "teacherName", "price", "imageUrl"])
        && d.name is string
        && d.description is string
        && d.teacherName is string
        && d.price is number
        && d.imageUrl is string;
    }

    function validSlot() {
      let d = request.resource.data;
      return d.keys().hasAll(["subjectId", "date", "time", "capacity", "bookedCount"])
        && d.subjectId is string
        && d.date is string
        && d.time is string
        && d.capacity is number
        && d.bookedCount is number
        && d.bookedCount >= 0
        && d.bookedCount <= d.capacity;
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && validSubject();
      allow delete: if isAdmin();
    }

    // Student-side booking transaction integrity, enforced server-side:
    //  • ONLY bookedCount may change (all other fields must stay identical)
    //  • booking: +1, must stay within capacity, AND a matching
    //    bookings/{slotId}_{uid} doc must be created in the SAME transaction
    //  • cancelling: -1, must not go below zero, AND the matching bookings
    //    doc must be deleted in the SAME transaction
    // A student cannot change bookedCount in any other way.
    function studentBookingTx(slotId) {
      let before = resource.data;
      let after = request.resource.data;
      let onlyCountChanged = after.diff(before).affectedKeys().hasOnly(["bookedCount"]);
      let bookingPath = /databases/$(database)/documents/bookings/$(slotId + "_" + request.auth.uid);
      return isSignedIn() && onlyCountChanged && (
        (after.bookedCount == before.bookedCount + 1
          && after.bookedCount <= before.capacity
          && getAfter(bookingPath).data.userId == request.auth.uid
          && getAfter(bookingPath).data.slotId == slotId)
        ||
        (after.bookedCount == before.bookedCount - 1
          && after.bookedCount >= 0
          && !existsAfter(bookingPath))
      );
    }

    match /slots/{slotId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && validSlot();
      allow update: if (isAdmin() && validSlot()) || studentBookingTx(slotId);
      allow delete: if isAdmin();
    }

    // ===================== Bookings (created by students via /booking) =====================
    // Document ID is ALWAYS "{slotId}_{userId}" — this makes double-booking
    // the same slot impossible (create on an existing doc fails) and lets
    // the rules above/below cross-check both sides of the transaction with
    // get/getAfter.

    function validBooking() {
      let d = request.resource.data;
      return d.keys().hasAll(["studentId", "slotId", "subjectId", "subjectName", "teacherName", "date", "time", "status", "createdAt"])
        && d.studentId == request.auth.uid
        && d.slotId is string
        && d.subjectId is string
        && d.subjectName is string
        && d.teacherName is string
        && d.date is string
        && d.time is string
        && d.status == "confirmed"
        && d.createdAt is timestamp;
    }

    // A paid subscriber: the Fatorak webhook (Admin SDK) is the ONLY writer
    // of `subscribed` — clients are blocked by onlySelfManagedFieldsChanged(),
    // so trusting this flag here is safe. Expiry is flipped by the cron job.
    function isSubscriber() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscribed == true;
    }

    match /bookings/{bookingId} {
      // Students see only their own bookings; the admin sees everything.
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);

      // A booking can ONLY be created as part of the booking transaction that
      // also increments the slot's bookedCount by exactly one (checked both
      // here and in the slots rule above, so neither write can happen alone) —
      // AND the caller must be a paid subscriber (or the admin). Unsubscribed
      // students cannot book even by calling the Firestore API directly.
      allow create: if (isAdmin() || isSubscriber())
        && bookingId == request.resource.data.slotId + "_" + request.auth.uid
        && validBooking()
        && getAfter(/databases/$(database)/documents/slots/$(request.resource.data.slotId)).data.bookedCount
           == get(/databases/$(database)/documents/slots/$(request.resource.data.slotId)).data.bookedCount + 1;

      // Cancelling = deleting your own booking. The client transaction also
      // decrements bookedCount, and the slots rule REQUIRES this deletion for
      // any decrement, so counts can never drift downward out of sync.
      // (Deleting without decrementing is allowed — worst case a seat stays
      // marked as taken, which fails safe. Admin can fix counts in /admin.)
      allow delete: if isSignedIn() && resource.data.studentId == request.auth.uid;

      // Bookings are immutable for students — cancel & re-book instead.
      allow update: if isAdmin();
    }

    // Everything else (if any future collections are added): deny by default,
    // admin only. Do NOT widen this to `allow write: if isAdmin()` covering
    // /users/** again — that would re-open the escalation path above.
    // ------------------------------------------------------------------
    // scheduleRequests — "جدولي" one-time (50 EGP) planner service.
    // Client can ONLY create its own unpaid intake form. The paid flag and
    // the pending status are stamped exclusively by the Fatorak webhook
    // (Admin SDK, bypasses rules). Fulfillment (image + fulfilled status)
    // is admin-only via the admin panel.
    // ------------------------------------------------------------------
    match /scheduleRequests/{requestId} {
      allow get, list: if isAdmin() ||
        (isSignedIn() && resource.data.studentId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ["studentId", "studentEmail", "studentUuid", "intake", "status", "paid", "createdAt"])
        && request.resource.data.keys().hasAll(["studentId", "intake", "status", "paid", "createdAt"])
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.paid == false
        && request.resource.data.status == "awaiting_payment"
        && request.resource.data.intake.fullName is string
        && request.resource.data.intake.fullName.size() >= 2
        && request.resource.data.intake.fullName.size() <= 80;

      // Students cannot update AT ALL (intake immutable; paid/status never
      // client-set). Admin updates for fulfillment only.
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // lectures — recorded-video marketplace. The top-level doc is a PUBLIC
    // catalog entry (title/price/teacher...). The actual media (video URL,
    // notes PDF path) lives in lectures/{id}/private/media and is readable
    // ONLY by: an admin, or anyone while the lecture is free/preview, or a
    // student holding the matching lecturePurchases/{lectureId}_{uid} doc
    // (created exclusively by the Fatorak webhook via Admin SDK).
    // ------------------------------------------------------------------
    match /lectures/{lectureId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /private/{docId} {
        allow read: if isAdmin() || (
          isSignedIn() && (
            get(/databases/$(database)/documents/lectures/$(lectureId)).data.priceEgp == 0 ||
            get(/databases/$(database)/documents/lectures/$(lectureId)).data.isFreePreview == true ||
            exists(/databases/$(database)/documents/lecturePurchases/$(lectureId)_$(request.auth.uid))
          )
        );
        // Media (videoUrl / notesPdfPath) is authored from the admin panel.
        allow write: if isAdmin();
      }
    }

    // lecturePurchases — proof of payment. Server-only writes (webhook);
    // students read only their own, admin reads all.
    match /lecturePurchases/{purchaseId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ------------------------------------------------------------------
    // رسائل 💬 — conversations. Exactly 2 members per room:
    //   • "dm"      → subscriber ↔ subscriber (client get()-verifies BOTH
    //                  users docs' `subscribed` flag here in rules)
    //   • "support" → admin ↔ ANY user (paid or not) — opened by admin
    //                  only; a non-subscriber may REPLY inside support.
    // Updates are limited to the lastMessage* preview fields a member bumps
    // when sending. Messages (subcollection) are create-only.
    // ------------------------------------------------------------------
    match /conversations/{convId} {
      allow read: if isAdmin() ||
        (isSignedIn() && request.auth.uid in resource.data.members);

      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(
          ["members", "type", "memberLabels", "lastMessageText", "lastMessageAt", "createdAt"]
        ) &&
        request.resource.data.members is list &&
        request.resource.data.members.size() == 2 &&
        request.resource.data.members[0] != request.resource.data.members[1] &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.memberLabels is map &&
        request.resource.data.lastMessageText is string &&
        request.resource.data.lastMessageAt is string &&
        request.resource.data.createdAt is string &&
        (
          (
            // dm — BOTH members must be subscribers.
            request.resource.data.type == "dm" &&
            get(/databases/$(database)/documents/users/$(request.resource.data.members[0])).data.subscribed == true &&
            get(/databases/$(database)/documents/users/$(request.resource.data.members[1])).data.subscribed == true
          ) ||
          (
            // support — opened BY an admin, one member is admin.
            request.resource.data.type == "support" &&
            isAdmin() &&
            (
              get(/databases/$(database)/documents/users/$(request.resource.data.members[0])).data.role == "admin" ||
              get(/databases/$(database)/documents/users/$(request.resource.data.members[1])).data.role == "admin"
            )
          )
        );

      // Members may only bump the preview fields when sending a message.
      allow update: if isAdmin() ||
        (isSignedIn() &&
          request.auth.uid in resource.data.members &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastMessageText", "lastMessageAt"]));

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAdmin() ||
          (isSignedIn() &&
            request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members);

        // NOTE on size(): rules measure strings in BYTES — Arabic is ~2
        // bytes/char, so 4000B ≈ the client's 2000-char cap. The client
        // (lib/messages.ts validateMessageText) enforces the exact
        // 2000-CHAR limit; this rule is the abuse ceiling.
        allow create: if isSignedIn() &&
          exists(/databases/$(database)/documents/conversations/$(convId)) &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members &&
          request.resource.data.keys().hasOnly(["senderId", "text", "fromPlatform", "createdAt"]) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() >= 1 &&
          request.resource.data.text.size() <= 4000 &&
          request.resource.data.fromPlatform is bool &&
          request.resource.data.createdAt is string &&
          (
            // support rooms: any member may talk (incl. non-subscribers).
            get(/databases/$(database)/documents/conversations/$(convId)).data.type == "support" ||
            // dm rooms: sender must be subscribed.
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscribed == true
          ) &&
          (
            // platform-branded messages («مِعافر 🤖») are an admin privilege.
            request.resource.data.fromPlatform == false ||
            (request.resource.data.fromPlatform == true && isAdmin())
          );

        // Immutable history — no edits, no deletes.
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read: if isAdmin();
    }
  }
}
