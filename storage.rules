rules_version = '2';
// Firebase Storage rules — fulfillment images for the "جدولي" planner service.
// Admin uploads the hand-built schedule image; ONLY the student who owns the
// matching scheduleRequests doc (or an admin) can read it.
// NOTE: Storage must be ENABLED in the Firebase console and these rules
// published there (Storage → Rules), same as firestore.rules.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /planner-fulfillments/{requestId}/{fileName} {
      // Admin-only uploads; images up to 5 MB.
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Owner (matched live against the Firestore request doc) or admin.
      allow read: if request.auth != null && (
        isAdmin() ||
        firestore.get(/databases/(default)/documents/scheduleRequests/$(requestId)).data.studentId == request.auth.uid
      );
    }

    // Lecture thumbnails — public marketing images (shown on catalog cards).
    match /lecture-thumbs/{lectureId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Lecture notes (PDF) — same access as the video: owner-purchaser/admin,
    // or anyone while the lecture itself is free/preview.
    match /lecture-notes/{lectureId}/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        firestore.get(/databases/(default)/documents/lectures/$(lectureId)).data.priceEgp == 0 ||
        firestore.get(/databases/(default)/documents/lectures/$(lectureId)).data.isFreePreview == true ||
        firestore.exists(/databases/(default)/documents/lecturePurchases/$(lectureId)_$(request.auth.uid))
      );
      allow write: if isAdmin()
        && request.resource.size < 15 * 1024 * 1024
        && (request.resource.contentType == 'application/pdf' ||
            request.resource.contentType.matches('image/.*'));
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
