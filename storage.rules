rules_version = '2';
// Firebase Storage rules — fulfillment images for the "جدولي" planner service.
// Admin uploads the hand-built schedule image; ONLY the student who owns the
// matching scheduleRequests doc (or an admin) can read it.
// NOTE: Storage must be ENABLED in the Firebase console and these rules
// published there (Storage → Rules), same as firestore.rules.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /planner-fulfillments/{requestId}/{fileName} {
      // Admin-only uploads; images up to 5 MB.
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Owner (matched live against the Firestore request doc) or admin.
      allow read: if request.auth != null && (
        isAdmin() ||
        firestore.get(/databases/(default)/documents/scheduleRequests/$(requestId)).data.studentId == request.auth.uid
      );
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
